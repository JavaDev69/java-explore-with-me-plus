{
  "info": {
    "_postman_id": "c08b5e73-e51d-4182-b256-0d2dbf9265dd",
    "name": "\"Explore with me\" API статистика Copy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
