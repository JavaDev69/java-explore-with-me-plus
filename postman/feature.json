  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Инициализируем счётчики, если их нет\r",
          "if (!pm.collectionVariables.get(\"userCounter\")) {\r",
          "    pm.collectionVariables.set(\"userCounter\", 1);\r",
          "}\r",
          "if (!pm.collectionVariables.get(\"categoryCounter\")) {\r",
          "    pm.collectionVariables.set(\"categoryCounter\", 1);\r",
          "}\r",
          "if (!pm.collectionVariables.get(\"eventCounter\")) {\r",
          "    pm.collectionVariables.set(\"eventCounter\", 1);\r",
          "}\r",
          "\r",
          "console.log(\"Счётчики инициализированы:\", {\r",
          "    userCounter: pm.collectionVariables.get(\"userCounter\"),\r",
          "    categoryCounter: pm.collectionVariables.get(\"categoryCounter\"),\r",
          "    eventCounter: pm.collectionVariables.get(\"eventCounter\")\r",
          "});\r",
          "\r",
          "// Сохраняем функции в глобальные переменные в виде строк\r",
          "pm.globals.set(\"createUser\", createUser.toString());\r",
          "pm.globals.set(\"createCategory\", createCategory.toString());\r",
          "pm.globals.set(\"createEvent\", createEvent.toString());\r",
          "pm.globals.set(\"sendModerationComment\", sendModerationComment.toString());\r",
          "\r",
          "pm.globals.set(\"testDataFunctionsLoaded\", true);\r",
          "\r",
          "console.log(\"Функции сохранены в глобальные переменные\");\r",
          "\r",
          "\r",
          "try {\r",
          "    const moment = require('moment');\r",
          "    console.log(\"Библиотека moment доступна\");\r",
          "} catch (e) {\r",
          "    console.error(\"Библиотека moment не найдена. Установите её или используйте альтернативный метод работы с датами\");\r",
          "}\r",
          "\r",
          "async function createUser() {\r",
          "    const userCounter = pm.collectionVariables.get(\"userCounter\") || 1;\r",
          "    const userName = `User_${userCounter}`;\r",
          "    const email = `mail_${userCounter}@test.com`;\r",
          "\r",
          "    pm.collectionVariables.set(\"userCounter\", userCounter + 1);\r",
          "\r",
          "    return new Promise((resolve, reject) => {\r",
          "        pm.sendRequest({\r",
          "            url: `${pm.collectionVariables.get(\"base_url\")}/admin/users`,\r",
          "            method: 'POST',\r",
          "            header: { 'Content-Type': 'application/json' },\r",
          "            body: {\r",
          "                mode: 'raw',\r",
          "                raw: JSON.stringify({ name: userName, email: email })\r",
          "            }\r",
          "        }, (err, response) => {\r",
          "            if (err) {\r",
          "                console.error(\"Ошибка при создании пользователя:\", err);\r",
          "                reject(err);\r",
          "            } else if (response.code === 201) {\r",
          "                const userId = response.json().id;\r",
          "                pm.collectionVariables.set(\"currentUserId\", userId);\r",
          "                console.log(\"Создан пользователь с ID:\", userId);\r",
          "                resolve(userId);\r",
          "            } else {\r",
          "                console.error(\"Ошибка создания пользователя, код:\", response.code);\r",
          "                reject(new Error(`HTTP ${response.code}`));\r",
          "            }\r",
          "        });\r",
          "    });\r",
          "}\r",
          "\r",
          "async function createCategory() {\r",
          "    const categoryCounter = pm.collectionVariables.get(\"categoryCounter\") || 1;\r",
          "    const categoryName = `Category_${categoryCounter}`;\r",
          "\r",
          "    pm.collectionVariables.set(\"categoryCounter\", categoryCounter + 1);\r",
          "\r",
          "    return new Promise((resolve, reject) => {\r",
          "        pm.sendRequest({\r",
          "            url: `${pm.collectionVariables.get(\"base_url\")}/admin/categories`,\r",
          "            method: 'POST',\r",
          "            header: { 'Content-Type': 'application/json' },\r",
          "            body: {\r",
          "                mode: 'raw',\r",
          "                raw: JSON.stringify({ name: categoryName })\r",
          "            }\r",
          "        }, (err, response) => {\r",
          "            if (err) {\r",
          "                console.error(\"Ошибка при создании категории:\", err);\r",
          "                reject(err);\r",
          "            } else if (response.code === 201) {\r",
          "                const categoryId = response.json().id;\r",
          "                pm.collectionVariables.set(\"currentCategoryId\", categoryId);\r",
          "                console.log(\"Создана категория с ID:\", categoryId);\r",
          "                resolve(categoryId);\r",
          "            } else {\r",
          "                console.error(\"Ошибка создания категории, код:\", response.code);\r",
          "                reject(new Error(`HTTP ${response.code}`));\r",
          "            }\r",
          "        });\r",
          "    });\r",
          "}\r",
          "\r",
          "async function createEvent(eventNumber) {\r",
          "    const eventCounter = pm.collectionVariables.get(\"eventCounter\") || 1;\r",
          "    const userId = parseInt(pm.collectionVariables.get(\"currentUserId\"));\r",
          "    const categoryId = pm.collectionVariables.get(\"currentCategoryId\");\r",
          "\r",
          "    if (!userId || !categoryId) {\r",
          "        throw new Error(\"Отсутствуют обязательные ID: пользователя или категории\");\r",
          "    }\r",
          "\r",
          "    const moment = require('moment');\r",
          "    const eventDate = moment().add(3, 'hours').format('YYYY-MM-DD HH:mm:ss');\r",
          "\r",
          "    pm.collectionVariables.set(\"eventCounter\", eventCounter + 1);\r",
          "\r",
          "    return new Promise((resolve, reject) => {\r",
          "        const url = `${pm.collectionVariables.get(\"base_url\")}/users/${userId}/events`;\r",
          "\r",
          "        pm.sendRequest({\r",
          "            url: url,\r",
          "            method: 'POST',\r",
          "            header: { 'Content-Type': 'application/json' },\r",
          "            body: {\r",
          "                mode: 'raw',\r",
          "                raw: JSON.stringify({\r",
          "                    title: `Test Event ${eventNumber}`,\r",
          "            annotation: `Event annotationAAAAAAAAAAAAAAAA ${eventNumber}`,\r",
          "            description: `Event description AAAAAAAAAAAAAAAAAAAAA ${eventNumber}`,\r",
          "            eventDate: eventDate,\r",
          "            category: categoryId,\r",
          "            location: { lat: 55.751244, lon: 37.618423 },\r",
          "            paid: false,\r",
          "            participantLimit: 0,\r",
          "            requestModeration: true\r",
          "                })\r",
          "            }\r",
          "        }, (err, response) => {\r",
          "            if (err) {\r",
          "                console.error(`Ошибка при создании события ${eventNumber}:`, err);\r",
          "                reject(err);\r",
          "            } else if (response.code === 201) {\r",
          "                const eventId = response.json().id;\r",
          "                pm.collectionVariables.set(`eventId_${eventNumber}`, eventId);\r",
          "                console.log(`Создано событие ${eventNumber} с ID:`, eventId);\r",
          "                resolve(eventId);\r",
          "            } else {\r",
          "                console.error(`Ошибка создания события ${eventNumber}, код:`, response.code);\r",
          "                reject(new Error(`HTTP ${response.code}`));\r",
          "            }\r",
          "        });\r",
          "    });\r",
          "}\r",
          "\r",
          "async function sendModerationComment(eventId) {\r",
          "    const moment = require('moment');\r",
          "\r",
          "    const requestBody = {\r",
          "        stateAction: \"REJECT_EVENT\",\r",
          "        moderationComment: \"Мероприятие нарушает правила платформы: содержание не соответствует тематике\"\r",
          "    };\r",
          "\r",
          "    return new Promise((resolve, reject) => {\r",
          "        const url = `${pm.collectionVariables.get(\"base_url\")}/admin/events/${eventId}`;\r",
          "\r",
          "        pm.sendRequest({\r",
          "            url: url,\r",
          "            method: 'PATCH',\r",
          "            header: {\r",
          "                'Content-Type': 'application/json'\r",
          "            },\r",
          "            body: {\r",
          "                mode: 'raw',\r",
          "                raw: JSON.stringify(requestBody)\r",
          "            }\r",
          "        }, (err, response) => {\r",
          "            if (err) {\r",
          "                console.error(\"Ошибка при отправке комментария модерации:\", err);\r",
          "                reject(err);\r",
          "            } else if (response.code === 200) {\r",
          "                console.log(\"Комментарий модерации успешно отправлен для события ID:\", eventId);\r",
          "                resolve(response.json());\r",
          "            } else {\r",
          "                console.error(\"Ошибка отправки комментария модерации, код:\", response.code);\r",
          "                console.error(\"Тело ответа сервера:\", response.json());\r",
          "                reject(new Error(`HTTP ${response.code}`));\r",
          "            }\r",
          "        });\r",
          "    });\r",
          "}\r",
          "\r",
          "\r",
          "\r",
          "// ЗАПУСКАЕМ создание тестовых данных ПОСЛЕ определения всех функций\r",
          "(async () => {\r",
          "    try {\r",
          "        console.log(\"Начинаем создание тестовых данных для коллекции...\");\r",
          "\r",
          "        await createUser();\r",
          "        await createCategory();\r",
          "        await createEvent(1);\r",
          "        await createEvent(2);\r",
          "\r",
          "        console.log(\"✅ Все тестовые данные успешно созданы для коллекции!\");\r",
          "\r",
          "        // Сохраняем ID для использования в запросах\r",
          "        const userId = pm.collectionVariables.get(\"currentUserId\");\r",
          "        const categoryId = pm.collectionVariables.get(\"currentCategoryId\");\r",
          "        const eventId1 = pm.collectionVariables.get(\"eventId_1\");\r",
          "        const eventId2 = pm.collectionVariables.get(\"eventId_2\");\r",
          "\r",
          "        pm.collectionVariables.set(\"testDataReady\", true);\r",
          "        console.log(\"Тестовые данные готовы. ID:\", { userId, categoryId, eventId1, eventId2 });\r",
          "    } catch (error) {\r",
          "        console.error(\"❌ Ошибка при создании тестовых данных:\", error);\r",
          "        throw error;\r",
          "    }\r",
          "})();"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
