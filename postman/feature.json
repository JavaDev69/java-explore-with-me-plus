                "exec": [
                  "pm.test(\"Статус ответа — 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const responseData = pm.response.json();\r",
                  "const event = responseData[0];\r",
                  "\r",
                  "pm.test(\"state равен CANCELED\", function () {\r",
                  "    pm.expect(event.state).to.equal(\"CANCELED\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"lastModerationCommentDto не null\", function () {\r",
                  "    pm.expect(event.lastModerationCommentDto).to.not.equal(null);\r",
                  "    pm.expect(event.lastModerationCommentDto.commentText).to.be.a(\"string\").that.is.not.empty;\r",
