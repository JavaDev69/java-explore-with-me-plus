	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"API = class {",
					"    constructor(pm) {",
					"        this.pm = pm;",
					"        this.baseUrl = pm.collectionVariables.get('baseUrl');",
					"    }",
					"",
					"    async addUser(user) {",
					"        return this.post('/admin/users', user, 'Ошибка при создании пользователя');",
					"    }",
					"",
					"    async addCategory(category) {",
					"        return this.post('/admin/categories', category, 'Ошибка при создании категории');",
					"    }",
					"",
					"    async addEvent(userId, event) {",
					"        return this.post('/users/' + userId + '/events', event, 'Ошибка при создании события');",
					"    }",
					"",
					"    async publishEvent(eventId) {",
					"        return this.patch('/admin/events/' + eventId, {stateAction: 'PUBLISH_EVENT'}, 'Ошибка при публикации события');",
					"    }",
					"",
					"    async subscribe(userId, publisherId) {",
					"        return this.post('/users/' + userId + '/subscriptions/' + publisherId, null, 'Ошибка при создании подписки', true);",
					"    }",
					"",
					"    async post(path, body, errorText, allowEmpty = false) {",
					"        return this.sendRequest('POST', path, body, errorText, allowEmpty);",
					"    }",
					"",
					"    async patch(path, body, errorText, allowEmpty = false) {",
					"        return this.sendRequest('PATCH', path, body, errorText, allowEmpty);",
					"    }",
					"",
					"    async sendRequest(method, path, body = null, errorText = 'Ошибка при выполнении запроса', allowEmpty = false) {",
					"        return new Promise((resolve, reject) => {",
					"            const request = {",
					"                url: this.baseUrl + path,",
					"                method: method,",
					"                header: { 'Content-Type': 'application/json', 'Accept': 'application/json' }",
					"            };",
					"            if (body !== null) {",
					"                request.body = { mode: 'raw', raw: JSON.stringify(body) };",
					"            }",
					"",
					"            this.pm.sendRequest(request, (error, response) => {",
					"                if (error || response.code >= 400) {",
					"                    const details = error ? error : response.text();",
					"                    reject(new Error(errorText + ': ' + details));",
					"                    return;",
					"                }",
					"                if (response.text() === '') {",
					"                    if (allowEmpty) {",
					"                        resolve(null);",
					"                        return;",
					"                    }",
					"                    reject(new Error(errorText + ': пустое тело ответа'));",
					"                    return;",
					"                }",
					"                resolve(response.json());",
					"            });",
					"        });",
					"    }",
					"};",
					"",
					"RandomUtils = class {",
					"    getUser() {",
					"        return {",
					"            name: pm.variables.replaceIn('{{$randomFullName}}'),",
					"            email: Date.now() + '.' + Math.floor(Math.random() * 1000000) + '@example.com'",
					"        };",
					"    }",
					"",
					"    getCategory() {",
					"        return {",
					"            name: 'cat-' + Date.now() + '-' + Math.floor(Math.random() * 1000000)",
					"        };",
					"    }",
					"",
					"    getEvent(categoryId, hourShift = 48) {",
					"        return {",
					"            annotation: 'Annotation for subscription feature test with enough characters',",
					"            category: categoryId,",
					"            description: 'Description for subscription feature test with enough characters',",
					"            eventDate: this.getFutureDateTime(hourShift),",
					"            location: {",
					"                lat: 55.75,",
					"                lon: 37.62",
					"            },",
					"            paid: false,",
					"            participantLimit: 10,",
					"            requestModeration: true,",
					"            title: 'Subscription feature event ' + Date.now() + '-' + Math.floor(Math.random() * 1000000)",
					"        };",
					"    }",
					"",
					"    getFutureDateTime(hourShift = 48) {",
					"        const moment = require('moment');",
					"        return moment().add(hourShift, 'hour').format('YYYY-MM-DD HH:mm:ss');",
					"    }",
					"};"
				]
			}
		}
	],
