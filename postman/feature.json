				{
					"name": "Получение актуальных опубликованных событий по подписке",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const main = async () => {",
									"    const api = new API(pm);",
									"    const rnd = new RandomUtils();",
									"    const subscriber = await api.addUser(rnd.getUser());",
									"    const publisherOne = await api.addUser(rnd.getUser());",
									"    const publisherTwo = await api.addUser(rnd.getUser());",
									"    const notSubscribedPublisher = await api.addUser(rnd.getUser());",
									"    const category = await api.addCategory(rnd.getCategory());",
									"",
									"    const olderEvent = await api.addEvent(publisherOne.id, rnd.getEvent(category.id, 48));",
									"    const newerEvent = await api.addEvent(publisherTwo.id, rnd.getEvent(category.id, 96));",
									"    const notSubscribedEvent = await api.addEvent(notSubscribedPublisher.id, rnd.getEvent(category.id, 120));",
									"    const pendingEvent = await api.addEvent(publisherOne.id, rnd.getEvent(category.id, 144));",
									"",
									"    await api.publishEvent(olderEvent.id);",
									"    await api.publishEvent(newerEvent.id);",
									"    await api.publishEvent(notSubscribedEvent.id);",
									"    await api.subscribe(subscriber.id, publisherOne.id);",
									"    await api.subscribe(subscriber.id, publisherTwo.id);",
									"",
									"    pm.collectionVariables.set('subscriberId', subscriber.id);",
									"    pm.collectionVariables.set('olderEventId', olderEvent.id);",
									"    pm.collectionVariables.set('newerEventId', newerEvent.id);",
									"    pm.collectionVariables.set('notSubscribedEventId', notSubscribedEvent.id);",
									"    pm.collectionVariables.set('pendingEventId', pendingEvent.id);",
									"};",
									"",
									"const interval = setInterval(() => {}, 1000);",
									"setTimeout(async () => {",
									"    try {",
									"        await main();",
									"    } catch (err) {",
									"        console.error('Ошибка при подготовке тестовых данных.', err);",
									"    } finally {",
									"        clearInterval(interval);",
									"    }",
									"}, 100);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Лента подписок должна вернуть 200 OK и JSON-массив', function () {",
									"    pm.response.to.be.ok;",
									"    pm.response.to.be.withBody;",
									"    pm.response.to.be.json;",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});",
									"",
									"pm.test('Лента содержит только события подписанных пользователей', function () {",
									"    const events = pm.response.json();",
									"    const ids = events.map(event => event.id);",
									"    pm.expect(ids).to.include(Number(pm.collectionVariables.get('olderEventId')));",
									"    pm.expect(ids).to.include(Number(pm.collectionVariables.get('newerEventId')));",
									"    pm.expect(ids).to.not.include(Number(pm.collectionVariables.get('notSubscribedEventId')));",
									"});",
									"",
									"pm.test('Лента содержит только опубликованные события', function () {",
									"    const ids = pm.response.json().map(event => event.id);",
									"    pm.expect(ids).to.not.include(Number(pm.collectionVariables.get('pendingEventId')));",
									"});",
									"",
									"pm.test('События отсортированы по eventDate по убыванию', function () {",
									"    const events = pm.response.json();",
									"    pm.expect(events.length).to.eql(2);",
									"    pm.expect(events[0].id).to.eql(Number(pm.collectionVariables.get('newerEventId')));",
									"    pm.expect(events[1].id).to.eql(Number(pm.collectionVariables.get('olderEventId')));",
									"    pm.expect(events[0].eventDate > events[1].eventDate).to.be.true;",
									"});"
								]
							}
						}
					],
