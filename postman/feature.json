                  "\r",
                  "const sendModerationComment = eval(`(${pm.globals.get(\"sendModerationComment\")})`);\r",
                  "const eventId1 = pm.collectionVariables.get(\"eventId_1\");\r",
                  "await sendModerationComment(eventId1);\r",
                  "\r",
                  "  "
