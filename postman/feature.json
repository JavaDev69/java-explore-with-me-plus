  "item": [
    {
      "name": "[User] Добавить комментарий к событию",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "4970ff14-ba77-4927-b22c-bce7d2780148",
            "exec": [
              "pm.test(\"Статус 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Тело ответа содержит id, text, authorName, status\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.haveOwnProperty('id');",
              "    pm.expect(json).to.haveOwnProperty('text');",
              "    pm.expect(json).to.haveOwnProperty('authorName');",
              "    pm.expect(json).to.haveOwnProperty('status');",
              "    pm.expect(json.status).to.equal('PENDING');",
              "});",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"text\": \"Отличное мероприятие! Надеюсь, будет ещё.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/1/events/1/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "1",
            "events",
            "1",
            "comments"
          ]
        }
      },
      "response": []
    },
    {
      "name": "[User] Получить комментарий по ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "4a996f80-ba4f-49bb-8a9c-647c5063c687",
            "exec": [
              "pm.test(\"Статус 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Ответ содержит все поля комментария\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.include.keys(['id', 'text', 'authorName', 'status', 'createdOn']);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/1/events/1/comments/1",
          "host": [
            "{{baseUrl}}"
