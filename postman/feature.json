    {
      "name": "[User] Получить все комментарии события",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "db3695dd-145a-42f5-ab8e-7c09ff936596",
            "exec": [
              "pm.test(\"Статус 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Ответ — массив комментариев\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(Array.isArray(json)).to.be.true;",
              "});",
              "",
              "if (pm.response.json().length > 0) {",
              "    pm.test(\"Первый комментарий содержит корректные поля\", function () {",
              "        const first = pm.response.json()[0];",
              "        pm.expect(first).to.have.all.keys('id', 'text', 'eventId', 'authorId', 'authorName', 'status', 'createdOn', 'updatedOn');",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}/events/{{eventId}}/comments?from=0&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
