      "name": "Admin_Moderation_Flow",
      "item": [
        {
          "name": "Admin_Get_Pending_Events",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус ответа — 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const responseData = pm.response.json();\r",
                  "const currentUserId = pm.collectionVariables.get(\"currentUserId\");\r",
                  "\r",
                  "// Фильтруем события, которые принадлежат текущему пользователю\r",
                  "const userEvents = responseData.filter(event =>\r",
                  "    event.initiator && event.initiator.id == currentUserId\r",
                  ");\r",
                  "\r",
                  "pm.test(\"Количество событий для текущего пользователя равно 2\", function () {\r",
                  "    pm.expect(userEvents.length).to.equal(2,\r",
                  "        `Ожидалось 2 события для пользователя ${currentUserId}, но получено ${userEvents.length}`\r",
                  "    );\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Все события пользователя в состоянии PENDING\", function () {\r",
                  "    userEvents.forEach((event, index) => {\r",
                  "        const eventNum = index + 1;\r",
                  "        pm.expect(event.state).to.equal(\"PENDING\",\r",
                  "            `Событие №${eventNum}: ожидалось state=PENDING, но получено ${event.state}`\r",
                  "        );\r",
                  "    });\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/events/moderation?",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
